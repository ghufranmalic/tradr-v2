# ── Shared database (Neon) — same value on Vercel and in this local .env ──
# Use the POOLED connection string from Neon (host contains -pooler)
# Never commit real values.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ── KTrade credentials — LOCAL ONLY. Never add these to Vercel. ──
# The collector runs from this machine (via `npm run sync-watcher`) so logins
# come from your own network, not a datacenter IP.
KTRADE_LOGIN_URL="https://example.ktrade.local/login"
KTRADE_DASHBOARD_URL="https://example.ktrade.local/dashboard"
KTRADE_USERNAME=""
KTRADE_PASSWORD=""
KTRADE_TOTP_SECRET=""
KTRADE_HEADLESS="true"
KTRADE_SESSION_STATE_PATH="playwright/.auth/ktrade.json"
KTRADE_USERNAME_SELECTOR="input[placeholder='Userid']"
KTRADE_PASSWORD_SELECTOR="input[placeholder='Password']"
KTRADE_SUBMIT_SELECTOR="#login-btn"
KTRADE_SECOND_LEVEL_PASSWORD=""
KTRADE_SECOND_LEVEL_PASSWORD_SELECTOR="#second-lvl-pwd-id"
KTRADE_SECOND_LEVEL_SUBMIT_SELECTOR="#auth2-pwd-btn"
KTRADE_WATCHLIST_URL_PATTERN="watchlist"
KTRADE_PORTFOLIO_URL_PATTERN="portfolio"
KTRADE_QUOTES_URL_PATTERN="TopSectorStocksFull"
# Optional direct JSON endpoint for quotes — skips page scraping entirely when set.
KTRADE_QUOTES_API_URL=""
# JSON selectors for KTrade's order ticket; required for live order placement.
# These match apps.ktrade.pk's webterminalv3 order form as of this writing — verify
# with `npm run ktrade:inspect-order-ticket` before trusting them, since that script
# fills the ticket but never submits, so you can check it populates correctly first.
# The "confirm" step (if KTrade shows a confirmation dialog after clicking Trade) is
# NOT included below — that can only be discovered by actually submitting an order
# yourself once, which nothing in this repo will do on your behalf.
KTRADE_ORDER_SELECTORS_JSON='{"openTicket":"#trade-symbol","symbolInput":"#trade-symbol","priceInput":"#trade-price","buySide":"#trade-side-buy","sellSide":"#trade-side-sell","quantityInput":"#trade-volume","submit":"#tradeorderbtn","errorBanner":".alert-danger"}'

# ── Auto-trade master switch — must ALSO be enabled in the dashboard's Trading tab ──
AUTO_TRADE_LIVE="false"

# ── Free-tier AI advisory layer (get a key at https://aistudio.google.com/apikey) ──
# Advisory only — never originates trades, only attaches rationale/confidence and
# can pause auto-approve if it disagrees with a quant-triggered proposal.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# ── Optional integrations ──
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_PRIVATE_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

MARKET_TIMEZONE="Asia/Karachi"
PRICE_DROP_ALERT_PERCENT="5"
